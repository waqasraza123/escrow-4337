{
  "name": "escrow4337",
  "private": true,
  "packageManager": "pnpm@9.7.0",
  "scripts": {
    "dev": "turbo run dev --parallel",
    "build": "turbo run build",
    "contracts:check": "./scripts/contracts-check.sh",
    "launch:candidate": "node ./scripts/launch-candidate.mjs",
    "verify:authority:deployed": "node ./scripts/deployed-authority-evidence.mjs",
    "verify:ci": "./scripts/verify-ci.sh",
    "verify:chain:local": "pnpm --filter escrow4334-api build && node ./services/api/scripts/run-built-cli.mjs dist/modules/operations/escrow-chain-sync-local-verification-runner.js",
    "verify:push": "./scripts/verify-push.sh",
    "test:scripts": "node --test scripts/*.test.mjs",
    "setup:githooks": "sh -c 'chmod +x .githooks/pre-push scripts/verify-push.sh scripts/safe-push.sh scripts/verify-ci.sh scripts/contracts-check.sh && if git rev-parse --git-dir >/dev/null 2>&1; then git config --local core.hooksPath .githooks; fi'",
    "safe-push": "./scripts/safe-push.sh",
    "e2e": "playwright test",
    "e2e:local": "PLAYWRIGHT_PROFILE=local playwright test",
    "e2e:smoke:local": "PLAYWRIGHT_PROFILE=local playwright test --project=local-smoke",
    "e2e:journeys:local": "PLAYWRIGHT_PROFILE=local PLAYWRIGHT_RETRIES=0 playwright test --project=local-journeys",
    "e2e:walkthrough:local": "PLAYWRIGHT_PROFILE=local PLAYWRIGHT_RETRIES=0 playwright test --project=local-walkthrough",
    "e2e:deployed": "PLAYWRIGHT_PROFILE=deployed playwright test",
    "e2e:smoke:deployed": "PLAYWRIGHT_PROFILE=deployed playwright test --project=deployed-smoke",
    "e2e:journeys:deployed": "PLAYWRIGHT_PROFILE=deployed PLAYWRIGHT_RETRIES=0 playwright test --project=deployed-seeded --project=deployed-exact",
    "e2e:canary:deployed": "PLAYWRIGHT_PROFILE=deployed PLAYWRIGHT_RETRIES=0 playwright test --project=deployed-seeded",
    "e2e:canary:deployed:exact": "PLAYWRIGHT_PROFILE=deployed PLAYWRIGHT_RETRIES=0 playwright test --project=deployed-exact",
    "e2e:walkthrough:deployed": "PLAYWRIGHT_PROFILE=deployed PLAYWRIGHT_RETRIES=0 playwright test --project=deployed-walkthrough",
    "e2e:deployed:list": "PLAYWRIGHT_PROFILE=deployed playwright test --list",
    "smoke:deployed": "pnpm e2e:smoke:deployed",
    "test": "turbo run test",
    "lint": "turbo run lint",
    "typecheck": "turbo run typecheck",
    "db:up": "docker compose --project-directory infra/postgres -f infra/postgres/docker-compose.yml up -d",
    "db:down": "docker compose --project-directory infra/postgres -f infra/postgres/docker-compose.yml down",
    "db:reset": "docker compose --project-directory infra/postgres -f infra/postgres/docker-compose.yml down -v",
    "db:status": "docker compose --project-directory infra/postgres -f infra/postgres/docker-compose.yml ps",
    "db:logs": "docker compose --project-directory infra/postgres -f infra/postgres/docker-compose.yml logs -f postgres",
    "prepare": "pnpm setup:githooks"
  },
  "devDependencies": {
    "@playwright/test": "^1.55.0",
    "@types/node": "^20.12.12",
    "eslint": "8.57.0",
    "eslint-config-next": "14.2.3",
    "husky": "^8.0.0",
    "lint-staged": "^15.2.2",
    "prettier": "^3.2.5",
    "turbo": "^2.1.3",
    "typescript": "^5.5.4"
  },
  "dependencies": {
    "@biconomy/account": "^4.5.7",
    "@biconomy/paymaster": "^3.1.4",
    "@ts-rest/core": "^3.52.1",
    "@ts-rest/nest": "^3.52.1",
    "@ts-rest/react-query": "^3.52.1",
    "dotenv": "^17.2.2",
    "drizzle-orm": "^0.44.5",
    "graphql": "^16.11.0",
    "graphql-request": "^7.2.0",
    "pg": "^8.16.3",
    "postgres": "^3.4.7",
    "siwe": "^3.0.0",
    "superjson": "^2.2.2"
  },
  "pnpm": {
    "overrides": {
      "eslint": "8.57.0",
      "eslint-plugin-react-hooks": "4.6.0"
    }
  }
}
