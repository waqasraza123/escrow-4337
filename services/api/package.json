{
  "name": "escrow4334-api",
  "version": "0.0.1",
  "description": "",
  "author": "",
  "private": true,
  "license": "UNLICENSED",
  "scripts": {
    "predev": "turbo run build --filter=@escrow4334/compliance",
    "dev": "nest start --watch",
    "prebuild": "turbo run build --filter=@escrow4334/compliance",
    "build": "nest build",
    "postbuild": "node ./scripts/copy-migrations.mjs",
    "format": "prettier --write \"src/**/*.ts\" \"test/**/*.ts\"",
    "start": "nest start",
    "start:dev": "nest start --watch",
    "start:debug": "nest start --debug --watch",
    "start:prod": "node dist/main",
    "db:migrate": "node ./scripts/run-built-cli.mjs dist/persistence/postgres/migration-runner.js",
    "db:migrate:status": "node ./scripts/run-built-cli.mjs dist/persistence/postgres/migration-runner.js --status",
    "deployment:validate": "node ./scripts/run-built-cli.mjs dist/modules/operations/deployment-validation-runner.js",
    "chain-sync:batch": "node ./scripts/run-built-cli.mjs dist/modules/operations/escrow-chain-sync-batch-runner.js",
    "chain-sync:daemon": "node ./scripts/run-built-cli.mjs dist/modules/operations/escrow-chain-sync-batch-daemon-runner.js",
    "chain-sync:daemon:health": "node ./scripts/run-built-cli.mjs dist/modules/operations/escrow-chain-sync-daemon-health-runner.js",
    "lint": "eslint \"{src,apps,libs,test}/**/*.ts\" --fix",
    "typecheck": "tsc -p tsconfig.json --noEmit --incremental false",
    "test": "jest --runInBand",
    "test:watch": "jest --watch",
    "test:cov": "jest --coverage",
    "test:debug": "node --inspect-brk -r tsconfig-paths/register -r ts-node/register node_modules/.bin/jest --runInBand",
    "test:e2e": "jest --config ./test/jest-e2e.json"
  },
  "dependencies": {
    "@escrow4334/compliance": "workspace:*",
    "@nestjs/common": "^11.0.1",
    "@nestjs/config": "^4.0.2",
    "@nestjs/core": "^11.0.1",
    "@nestjs/platform-express": "^11.0.1",
    "jose": "^6.1.0",
    "ethers": "^5.8.0",
    "pg": "^8.16.3",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.1",
    "siwe": "^3.0.0",
    "zod": "^4.1.9"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3.2.0",
    "@eslint/js": "^9.18.0",
    "@nestjs/cli": "^11.0.0",
    "@nestjs/schematics": "^11.0.0",
    "@nestjs/testing": "^11.0.1",
    "@types/express": "^5.0.0",
    "@types/jest": "^29.5.14",
    "@types/node": "^22.10.7",
    "@types/supertest": "^6.0.2",
    "eslint": "^9.18.0",
    "eslint-config-prettier": "^10.0.1",
    "eslint-plugin-prettier": "^5.2.2",
    "globals": "^16.0.0",
    "jest": "^29.7.0",
    "prettier": "^3.4.2",
    "source-map-support": "^0.5.21",
    "supertest": "^7.0.0",
    "ts-jest": "^29.4.1",
    "ts-loader": "^9.5.2",
    "ts-node": "^10.9.2",
    "tsconfig-paths": "^4.2.0",
    "typescript": "^5.7.3",
    "typescript-eslint": "^8.20.0"
  },
  "jest": {
    "preset": "ts-jest/presets/default-esm",
    "testEnvironment": "node",
    "rootDir": ".",
    "testMatch": [
      "<rootDir>/test/**/*.spec.ts"
    ],
    "moduleFileExtensions": [
      "ts",
      "js",
      "json"
    ],
    "extensionsToTreatAsEsm": [
      ".ts"
    ],
    "transform": {
      "^.+\\.ts$": [
        "ts-jest",
        {
          "useESM": true,
          "tsconfig": "<rootDir>/tsconfig.json"
        }
      ]
    },
    "moduleNameMapper": {
      "^jose$": "<rootDir>/test/mocks/jose.ts"
    }
  }
}
