{
  "expo": {
    "name": "Milestone Escrow",
    "slug": "escrow4337-mobile",
    "scheme": "escrow4337",
    "version": "0.1.0",
    "orientation": "portrait",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "assetBundlePatterns": ["**/*"],
    "ios": {
      "supportsTablet": true,
      "infoPlist": {
        "LSApplicationQueriesSchemes": [
          "metamask",
          "trust",
          "rainbow",
          "uniswap",
          "safe",
          "zerion",
          "coinbase-wallet"
        ]
      }
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#0b6b3a"
      }
    },
    "web": {
      "bundler": "metro",
      "output": "static"
    },
    "plugins": ["expo-router", "expo-secure-store"],
    "experiments": {
      "typedRoutes": true,
      "autolinkingModuleResolution": true
    },
    "extra": {
      "apiBaseUrl": "http://localhost:4100",
      "defaultCurrencyAddress": "",
      "reownProjectId": "",
      "walletConnectMetadataUrl": "https://escrow4337.local",
      "walletConnectIconUrl": "https://escrow4337.local/icon.png",
      "walletChainId": 84532
    }
  }
}
